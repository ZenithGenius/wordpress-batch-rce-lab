# Vulnerable by default (wp2shell affects 7.0.0-7.0.1 and 6.9.0-6.9.4).
# No patched Docker Hub image exists yet for 7.0.2/6.9.5, so the fix is
# demonstrated with ./apply-fix.sh, which applies the real upstream one-line
# patch to this running container's source (./restore-vuln.sh undoes it).
WP_IMAGE=wordpress:7.0.1-php8.3-apache
WP_PORT=8028
DB_ROOT_PASSWORD=labroot
DB_NAME=wp
DB_USER=wp
DB_PASSWORD=wp
